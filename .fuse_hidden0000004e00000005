        <div id="search-results" style="display:none;position:absolute;top:100%;right:8px;width:360px;max-height:70vh;overflow-y:auto;background:var(--surface);border:1px solid var(--border);border-radius:6px;box-shadow:0 8px 24px rgba(0,0,0,.4);z-index:200;margin-top:4px"></div>
