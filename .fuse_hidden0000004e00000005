<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Education Framework</title>
<style>
:root {
  --bg: #0f0f14;
  --surface: #1a1a24;
  --surface2: #23233a;
  --border: #2a2a40;
  --text: #e0e0e8;
  --text-muted: #8888a0;
  --accent: #6c8cff;
  --accent2: #ff8c6c;
  --accent3: #6cffa0;
  --accent4: #ffd76c;
  --warn: #ff6c6c;
  --intro: #4a4a6a;
  --ext: #6a4a4a;
  --verbal: #4a6a4a;
  --spatial: #6a6a4a;
  --hisens: #5a4a6a;
  --losens: #4a5a6a;
  --depth: #4a6a6a;
  --breadth: #6a4a5a;
}
* { margin:0; padding:0; box-sizing:border-box; }
body { font-family: 'Segoe UI', system-ui, -apple-system, sans-serif; background: var(--bg); color: var(--text); line-height: 1.65; }
a { color: var(--accent); text-decoration: none; }
a:hover { text-decoration: underline; }

/* LAYOUT */
.app { display: flex; flex-direction: column; min-height: 100vh; }
.topbar { background: var(--surface); border-bottom: 1px solid var(--border); padding: 0; position: sticky; top: 0; z-index: 100; }
.topbar-inner { max-width: 1400px; margin: 0 auto; display: flex; align-items: center; gap: 0; }
.logo { padding: 12px 20px; font-weight: 700; font-size: 14px; letter-spacing: 1px; text-transform: uppercase; color: var(--accent); white-space: nowrap; border-right: 1px solid var(--border); }
.tabs { display: flex; overflow-x: auto; flex: 1; }
.tab { padding: 14px 16px; font-size: 13px; cursor: pointer; color: var(--text-muted); border-bottom: 2px solid transparent; white-space: nowrap; transition: all .15s; }
.tab:hover { color: var(--text); background: rgba(108,140,255,.05); }
.tab.active { color: var(--accent); border-bottom-color: var(--accent); }
.main-layout { display: flex; flex: 1; max-width: 1400px; margin: 0 auto; width: 100%; }
.sidebar { width: 240px; min-width: 240px; background: var(--surface); border-right: 1px solid var(--border); padding: 20px 16px; position: sticky; top: 52px; height: calc(100vh - 52px); overflow-y: auto; }
.content { flex: 1; padding: 32px 40px; max-width: 900px; overflow-y: auto; }

/* SIDEBAR */
.sidebar-title { font-size: 11px; text-transform: uppercase; letter-spacing: 1.5px; color: var(--text-muted); margin-bottom: 12px; }
.profile-group { margin-bottom: 20px; }
.profile-label { font-size: 12px; color: var(--text-muted); margin-bottom: 6px; }
.radio-group { display: flex; gap: 2px; margin-bottom: 10px; }
.radio-btn { flex: 1; padding: 5px 4px; font-size: 11px; text-align: center; cursor: pointer; border-radius: 4px; background: var(--surface2); color: var(--text-muted); transition: all .15s; border: 1px solid transparent; }
.radio-btn:hover { color: var(--text); }
.radio-btn.active { background: var(--accent); color: #fff; border-color: var(--accent); }
.nav-links { margin-top: 24px; border-top: 1px solid var(--border); padding-top: 16px; }
.nav-link { display: block; padding: 5px 8px; font-size: 12px; color: var(--text-muted); cursor: pointer; border-radius: 4px; margin-bottom: 2px; }
.nav-link:hover { background: var(--surface2); color: var(--text); }

/* CONTENT */
h1 { font-size: 28px; font-weight: 700; margin-bottom: 8px; color: var(--text); }
h2 { font-size: 20px; font-weight: 600; margin: 36px 0 12px; color: var(--accent); border-bottom: 1px solid var(--border); padding-bottom: 8px; }
h3 { font-size: 16px; font-weight: 600; margin: 24px 0 8px; color: var(--text); }
.subtitle { font-size: 14px; color: var(--text-muted); margin-bottom: 24px; }
p { margin-bottom: 12px; font-size: 14px; }
.priority-box { background: linear-gradient(135deg, rgba(108,140,255,.1), rgba(108,255,160,.05)); border: 1px solid var(--accent); border-radius: 8px; padding: 20px; margin: 16px 0 24px; }
.priority-box h3 { margin-top: 0; color: var(--accent); }
.priority-item { padding: 6px 0; font-size: 14px; }
.priority-num { display: inline-block; width: 22px; height: 22px; background: var(--accent); color: #fff; border-radius: 50%; text-align: center; line-height: 22px; font-size: 11px; font-weight: 700; margin-right: 8px; }

/* TABLES */
table { width: 100%; border-collapse: collapse; margin: 12px 0 20px; font-size: 13px; }
th { background: var(--surface2); padding: 10px 12px; text-align: left; font-weight: 600; font-size: 12px; text-transform: uppercase; letter-spacing: .5px; color: var(--text-muted); border-bottom: 2px solid var(--border); }
td { padding: 10px 12px; border-bottom: 1px solid var(--border); vertical-align: top; }
tr:hover td { background: rgba(108,140,255,.03); }
td:first-child { font-weight: 600; color: var(--accent2); white-space: nowrap; width: 160px; }

/* TEMPERAMENT ADJUSTMENTS */
.t-adjust { display: none; margin: 8px 0; padding: 10px 14px; border-radius: 6px; font-size: 13px; border-left: 3px solid; }
.t-adjust.visible { display: block; }
.t-adjust.t-introvert { background: rgba(74,74,106,.2); border-color: #8888cc; }
.t-adjust.t-extrovert { background: rgba(106,74,74,.2); border-color: #cc8888; }
.t-adjust.t-verbal { background: rgba(74,106,74,.2); border-color: #88cc88; }
.t-adjust.t-spatial { background: rgba(106,106,74,.2); border-color: #cccc88; }
.t-adjust.t-high-sens { background: rgba(90,74,106,.2); border-color: #aa88cc; }
.t-adjust.t-low-sens { background: rgba(74,90,106,.2); border-color: #88aacc; }
.t-adjust.t-depth { background: rgba(74,106,106,.2); border-color: #88cccc; }
.t-adjust.t-breadth { background: rgba(106,74,90,.2); border-color: #cc88aa; }
.t-label { font-size: 10px; text-transform: uppercase; letter-spacing: 1px; opacity: .7; margin-bottom: 4px; }

/* CARDS */
.card { background: var(--surface); border: 1px solid var(--border); border-radius: 8px; padding: 16px 20px; margin: 12px 0; }
.card-title { font-weight: 600; font-size: 14px; margin-bottom: 6px; }
.card-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin: 12px 0; }
.tag { display: inline-block; padding: 2px 8px; font-size: 11px; border-radius: 12px; margin: 2px; }
.tag-game { background: rgba(108,140,255,.15); color: var(--accent); }
.tag-book { background: rgba(255,140,108,.15); color: var(--accent2); }
.tag-music { background: rgba(108,255,160,.15); color: var(--accent3); }
.tag-activity { background: rgba(255,215,108,.15); color: var(--accent4); }

/* SECTION CONTENT */
.section { display: none; }
.section.active { display: block; }
.age-content { display: none; }
.age-content.active { display: block; }
.warn-box { background: rgba(255,108,108,.08); border: 1px solid rgba(255,108,108,.3); border-radius: 8px; padding: 16px 20px; margin: 12px 0; }
.warn-box h3 { color: var(--warn); margin-top: 0; }
.note-box { background: rgba(108,140,255,.08); border: 1px solid rgba(108,140,255,.2); border-radius: 8px; padding: 16px 20px; margin: 12px 0; }
.music-track { display: flex; gap: 16px; margin: 8px 0; }
.music-track > div { flex: 1; padding: 12px; background: var(--surface); border: 1px solid var(--border); border-radius: 6px; }
.music-track h4 { font-size: 13px; color: var(--accent3); margin-bottom: 6px; }

/* FLOATING PROFILE PANEL */
.profile-fab { display: none; position: fixed; bottom: 20px; right: 20px; width: 48px; height: 48px; border-radius: 50%; background: var(--accent); color: #fff; border: none; cursor: pointer; z-index: 300; box-shadow: 0 4px 16px rgba(0,0,0,.4); font-size: 20px; line-height: 48px; text-align: center; transition: transform .15s; }
.profile-fab:hover { transform: scale(1.1); }
.profile-fab:active { transform: scale(0.95); }
.profile-float { display: none; position: fixed; bottom: 78px; right: 20px; width: 260px; background: var(--surface); border: 1px solid var(--border); border-radius: 10px; padding: 16px; z-index: 300; box-shadow: 0 8px 32px rgba(0,0,0,.5); }
.profile-float.open { display: block; }
.profile-float .profile-label { font-size: 12px; color: var(--text-muted); margin-bottom: 4px; }
.profile-float .radio-group { display: flex; gap: 2px; margin-bottom: 10px; }
.profile-float .radio-btn { flex: 1; padding: 7px 4px; font-size: 12px; text-align: center; cursor: pointer; border-radius: 4px; background: var(--surface2); color: var(--text-muted); transition: all .15s; border: 1px solid transparent; }
.profile-float .radio-btn.active { background: var(--accent); color: #fff; border-color: var(--accent); }
.profile-float-title { font-size: 11px; text-transform: uppercase; letter-spacing: 1.5px; color: var(--text-muted); margin-bottom: 12px; }
/* FLOATING SECTIONS NAV */
.float-nav-link { display: block; padding: 8px 12px; font-size: 13px; color: var(--text-muted); cursor: pointer; border-radius: 4px; margin-bottom: 2px; }
.float-nav-link:hover { background: var(--surface2); color: var(--text); }

/* TABLE SCROLL WRAPPER - applied via JS on mobile */
.table-scroll { overflow-x: auto; -webkit-overflow-scrolling: touch; margin: 12px -4px 20px; padding: 0 4px; }
.table-scroll table { min-width: 500px; }

/* RESPONSIVE */
@media (max-width: 900px) {
  .sidebar { display: none; }
  .content { padding: 20px 16px; max-width: 100%; }
  .card-grid { grid-template-columns: 1fr; }
  .music-track { flex-direction: column; }
  .logo { padding: 12px 14px; font-size: 12px; }
  .tab { padding: 12px 10px; font-size: 12px; }
  h1 { font-size: 22px; }
  h2 { font-size: 17px; }
  td:first-child { white-space: normal; width: auto; }
  .priority-box { padding: 14px; }
  .topbar-inner { flex-wrap: nowrap; }
  .tabs { flex: 1; min-width: 0; }
  .tabs::-webkit-scrollbar { height: 0; }
}
@media (max-width: 500px) {
  .logo { display: none; }
  .tab { padding: 12px 8px; font-size: 11px; }
}
@media print {
  .topbar, .sidebar, .profile-fab, .profile-float { display: none !important; }
  .content { max-width: 100%; padding: 20px; }
  .t-adjust { display: block !important; }
}
</style>
</head>
