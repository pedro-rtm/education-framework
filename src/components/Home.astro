---
interface Props {
  phaseCount: number;
  universeCount: number;
  lang?: string;
}
const { phaseCount, universeCount, lang = 'en' } = Astro.props;

const phases = [
  { id: 'age-0-1', label: '0–1', desc: lang === 'es' ? 'Fundaciones Neuronales' : 'Neural Foundations' },
  { id: 'age-1-3', label: '1–3', desc: lang === 'es' ? 'Explosión Lingüística y Motricidad' : 'Language Explosion & Motor Mastery' },
  { id: 'age-4-7', label: '4–7', desc: lang === 'es' ? 'Historias y Sistemas' : 'Stories & Systems' },
  { id: 'age-8-10', label: '8–10', desc: lang === 'es' ? 'Primeros Principios y Sistemas' : 'First Principles & Systems' },
  { id: 'age-11-13', label: '11–13', desc: lang === 'es' ? 'Profundidad y Complejidad' : 'Depth & Complexity' },
  { id: 'age-14-16', label: '14–16', desc: lang === 'es' ? 'Pensamiento Interdisciplinar' : 'Cross-Domain Thinking' },
  { id: 'age-17-18', label: '17–18', desc: lang === 'es' ? 'Síntesis y Lanzamiento' : 'Synthesis & Launch' },
];

const threads = [
  { id: 's-communication', icon: 'record_voice_over', label: lang === 'es' ? 'Comunicación' : 'Communication' },
  { id: 's-music', icon: 'music_note', label: lang === 'es' ? 'Música' : 'Music' },
  { id: 's-mind-body', icon: 'fitness_center', label: lang === 'es' ? 'Cuerpo y Mente' : 'Mind & Body' },
  { id: 's-social', icon: 'people', label: lang === 'es' ? 'Social' : 'Social' },
  { id: 's-making', icon: 'construction', label: lang === 'es' ? 'Construcción' : 'Making & Craft' },
  { id: 's-knowledge', icon: 'lightbulb', label: lang === 'es' ? 'Conocimiento' : 'Knowledge' },
  { id: 's-culture', icon: 'travel_explore', label: lang === 'es' ? 'Cultura' : 'Culture' },
];

const t = lang === 'es' ? {
  title: 'Marco Educativo',
  subtitle: `Un marco de desarrollo para edades de 0 a 18 años. Once objetivos, métodos basados en evidencia, ${universeCount} universos de contenido, calibrado al perfil de cada niño.`,
  framework: 'Marco',
  frameworkDesc: 'Filosofía, principios, once objetivos y guía operativa. La base sobre la que se construye todo lo demás.',
  frameworkMeta: '11 OBJETIVOS · 10 PRINCIPIOS · 19 MODELOS',
  curriculumLabel: 'Currículo',
  curriculumDesc: 'El mismo contenido, dos formas de navegarlo.',
  byAge: 'Por Edad',
  acrossAges: 'A Través de las Edades',
  targets: 'Mapa de Actividades', targetsMeta: '11 OBJETIVOS · 7 FASES',
  models: 'Modelos Mentales', modelsMeta: '19 MODELOS · 4 CAPAS',
  domains: 'Dominios', domainsMeta: 'HILOS CURRICULARES',
  resources: 'Recursos', resourcesMeta: 'LIBROS · JUGUETES · EQUIPAMIENTO',
  library: 'Biblioteca', libraryMeta: `${universeCount}+ UNIVERSOS`,
} : {
  title: 'Education Framework',
  subtitle: `A developmental framework for ages 0–18. Eleven targets, evidence-based methods, ${universeCount} content universes, calibrated to each child's profile.`,
  framework: 'Framework',
  frameworkDesc: 'Philosophy, principles, eleven targets, and operational guidance. The foundation everything else is built on.',
  frameworkMeta: '11 TARGETS · 10 PRINCIPLES · 19 MODELS',
  curriculumLabel: 'Curriculum',
  curriculumDesc: 'The same content, two ways to navigate it.',
  byAge: 'By Age',
  acrossAges: 'Across Ages',
  targets: 'Activity Map', targetsMeta: '11 TARGETS · 7 PHASES',
  models: 'Mental Models', modelsMeta: '19 MODELS · 4 LAYERS',
  domains: 'Domains', domainsMeta: 'CURRICULUM THREADS',
  resources: 'Resources', resourcesMeta: 'BOOKS · TOYS · EQUIPMENT',
  library: 'Library', libraryMeta: `${universeCount}+ UNIVERSES`,
};
---

<div class="home-view" id="home-view">
  <div class="home-hero">
    <h1 class="home-title">{t.title}</h1>
    <p class="home-subtitle">{t.subtitle}</p>
  </div>

  <div class="home-stack">
    <!-- 1. Framework — standalone -->
    <button type="button" class="home-card" data-nav="framework">
      <div class="home-card-inner">
        <div class="home-card-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
        </div>
        <div>
          <h2 class="home-card-title">{t.framework}</h2>
          <p class="home-card-desc">{t.frameworkDesc}</p>
          <span class="home-card-meta">{t.frameworkMeta}</span>
        </div>
      </div>
    </button>

    <!-- 2. Curriculum — two axes of the same content -->
    <div class="home-curriculum">
      <div class="home-curriculum-header">
        <div class="home-card-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 8v4l3 3"/><circle cx="12" cy="12" r="10"/></svg>
        </div>
        <h2 class="home-curriculum-title">{t.curriculumLabel}</h2>
        <p class="home-curriculum-desc">{t.curriculumDesc}</p>
      </div>

      <div class="home-curriculum-views">
        <!-- By Age -->
        <div class="home-curriculum-view">
          <h3 class="home-view-label">{t.byAge}</h3>
          <div class="home-phase-grid">
            {phases.map((phase) => (
              <button type="button" class="home-phase-pill" data-nav="age" data-phase-id={phase.id}>
                <span class="home-phase-age">{phase.label}</span>
                <span class="home-phase-desc">{phase.desc}</span>
              </button>
            ))}
          </div>
        </div>

        <div class="home-curriculum-divider"></div>

        <!-- Across Ages -->
        <div class="home-curriculum-view">
          <h3 class="home-view-label">{t.acrossAges}</h3>
          <div class="home-thread-grid">
            <button type="button" class="home-thread-pill" data-nav="targets">
              <span class="material-symbols-rounded home-thread-icon">emoji_events</span>
              <span class="home-thread-label">{t.targets}</span>
            </button>
            <button type="button" class="home-thread-pill" data-nav="models">
              <span class="material-symbols-rounded home-thread-icon">cognition</span>
              <span class="home-thread-label">{t.models}</span>
            </button>
            <button type="button" class="home-thread-pill" data-nav="domain">
              <span class="material-symbols-rounded home-thread-icon">category</span>
              <span class="home-thread-label">{t.domains}</span>
            </button>
            <button type="button" class="home-thread-pill" data-nav="resources">
              <span class="material-symbols-rounded home-thread-icon">local_library</span>
              <span class="home-thread-label">{t.resources}</span>
            </button>
            <button type="button" class="home-thread-pill" data-nav="universe">
              <span class="material-symbols-rounded home-thread-icon">menu_book</span>
              <span class="home-thread-label">{t.library}</span>
            </button>
      </div>
    </div>
  </div>
</div>
