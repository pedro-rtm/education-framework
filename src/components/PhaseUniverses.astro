---
import { getCollection } from 'astro:content';
import { ENGAGEMENT_MODE_LABELS, MODEL_LABELS, TARGET_LABELS } from '../data/universeTaxonomy';

interface Props {
  phaseId: string;
}
const { phaseId } = Astro.props;

const allUniverses = await getCollection('universes');

const tierOrder: Array<'foundational' | 'core' | 'recommended'> = ['foundational', 'core', 'recommended'];
const entries: Array<{
  id: string;
  label: string;
  tags: string[];
  tier: string;
  title: string;
  description: string;
  mode?: keyof typeof ENGAGEMENT_MODE_LABELS;
  goals?: string[];
  cautions?: string;
  targets?: Array<keyof typeof TARGET_LABELS>;
  models?: Array<keyof typeof MODEL_LABELS>;
}> = [];

for (const u of allUniverses) {
  for (const p of u.data.phases) {
    if (p.phaseId === phaseId) {
      entries.push({
        ...p,
        id: u.id,
        label: u.data.label,
        tags: u.data.tags,
        targets: u.data.targets,
        models: u.data.models,
      });
    }
  }
}

const grouped = tierOrder
  .map(tier => ({
    tier,
    label: tier === 'foundational' ? 'FOUNDATIONAL Anchors' : tier === 'core' ? 'CORE' : 'RECOMMENDED',
    items: entries.filter(e => e.tier === tier),
  }))
  .filter(g => g.items.length > 0);
---

{grouped.length > 0 && (
  <div class="phase-universes">
    <h2 id="s-content"><span class="material-symbols-rounded">auto_stories</span>Content & Universes</h2>
    <p class="subtitle">Anchor works get the full engagement cycle. Broader content is Absorb-mode. See <strong>Universes</strong> view for full detail and progression across ages.</p>
    {grouped.map(group => (
      <>
        <h3>{group.label}</h3>
        <div class="phase-universe-grid">
          {group.items.map(item => (
            <div class="phase-universe-compact" data-universe={item.id}>
              <div class="phase-universe-title">{item.label}</div>
              <div class="phase-universe-desc">{item.title}</div>
              {item.mode && <span class="universe-tag">{ENGAGEMENT_MODE_LABELS[item.mode]}</span>}
            </div>
          ))}
        </div>
      </>
    ))}
  </div>
)}
