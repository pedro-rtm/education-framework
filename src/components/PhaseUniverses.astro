---
import { getCollection } from 'astro:content';
import { ENGAGEMENT_MODE_LABELS, MODEL_LABELS, TARGET_LABELS } from '../data/universeTaxonomy';

interface Props {
  phaseId: string;
}
const { phaseId } = Astro.props;

const allUniverses = await getCollection('universes');

const tierOrder: Array<'foundational' | 'core' | 'recommended'> = ['foundational', 'core', 'recommended'];
const entries: Array<{
  id: string;
  label: string;
  tags: string[];
  tier: string;
  title: string;
  description: string;
  mode?: keyof typeof ENGAGEMENT_MODE_LABELS;
  goals?: string[];
  cautions?: string;
  targets?: Array<keyof typeof TARGET_LABELS>;
  models?: Array<keyof typeof MODEL_LABELS>;
}> = [];

for (const u of allUniverses) {
  for (const p of u.data.phases) {
    if (p.phaseId === phaseId) {
      entries.push({
        ...p,
        id: u.id,
        label: u.data.label,
        tags: u.data.tags,
        targets: u.data.targets,
        models: u.data.models,
      });
    }
  }
}

const grouped = tierOrder
  .map(tier => ({
    tier,
    label: tier === 'foundational' ? 'FOUNDATIONAL Anchors' : tier === 'core' ? 'CORE' : 'RECOMMENDED',
    items: entries.filter(e => e.tier === tier),
  }))
  .filter(g => g.items.length > 0);
---

{grouped.length > 0 && (
  <div class="phase-universes">
    <h2 id="s-content"><span class="material-symbols-rounded">auto_stories</span>Content & Universes</h2>
    <p class="subtitle">Click any item to see details for this age. See <strong>Universes</strong> view for full progression across all ages.</p>
    {grouped.map(group => (
      <>
        <h3>{group.label}</h3>
        <div class="phase-universe-grid">
          {group.items.map(item => (
            <details class="phase-universe-card" data-universe={item.id}>
              <summary class="phase-universe-summary">
                <span class="phase-universe-title">{item.label}</span>
                <span class="phase-universe-subtitle">{item.title}</span>
                {item.mode && <span class="universe-tag">{ENGAGEMENT_MODE_LABELS[item.mode]}</span>}
              </summary>
              <div class="phase-universe-detail">
                <p>{item.description}</p>
                {item.goals && item.goals.length > 0 && (
                  <div class="phase-universe-goals">
                    <strong>Focus:</strong>
                    <ul>
                      {item.goals.map(g => <li>{g}</li>)}
                    </ul>
                  </div>
                )}
                {item.cautions && (
                  <p class="phase-universe-caution"><strong>Caution:</strong> {item.cautions}</p>
                )}
                {(item.targets?.length || item.models?.length) && (
                  <div class="phase-universe-meta">
                    {(item.targets ?? []).slice(0, 3).map((target) => (
                      <span class="universe-tag">{TARGET_LABELS[target]}</span>
                    ))}
                    {(item.models ?? []).slice(0, 3).map((model) => (
                      <span class="universe-tag">{MODEL_LABELS[model]}</span>
                    ))}
                  </div>
                )}
                <button type="button" class="phase-universe-link" data-universe-nav={item.id}>View full journey across ages</button>
              </div>
            </details>
          ))}
        </div>
      </>
    ))}
  </div>
)}
