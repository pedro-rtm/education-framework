<div class="sidebar">
  <div class="sidebar-title">Child Profile</div>
  <div class="profile-group">
    <div class="profile-label">Energy <span class="info-toggle" data-tip="energy-tip">i</span></div>
    <div class="info-tip" id="energy-tip">Introvert: recharges alone. Extrovert: recharges with people.</div>
    <div class="radio-group" data-dim="energy">
      <div class="radio-btn" data-val="introvert">Introvert</div>
      <div class="radio-btn active" data-val="balanced">Balanced</div>
      <div class="radio-btn" data-val="extrovert">Extrovert</div>
    </div>
    <div class="profile-label">Processing <span class="info-toggle" data-tip="processing-tip">i</span></div>
    <div class="info-tip" id="processing-tip">Spatial: thinks in images/building. Verbal: thinks in words/arguments.</div>
    <div class="radio-group" data-dim="processing">
      <div class="radio-btn" data-val="spatial">Spatial</div>
      <div class="radio-btn active" data-val="balanced">Balanced</div>
      <div class="radio-btn" data-val="verbal">Verbal</div>
    </div>
    <div class="profile-label">Sensitivity <span class="info-toggle" data-tip="sensitivity-tip">i</span></div>
    <div class="info-tip" id="sensitivity-tip">High: overwhelmed by stimuli, needs gentle exposure. Low: needs more intensity.</div>
    <div class="radio-group" data-dim="sensitivity">
      <div class="radio-btn" data-val="high-sens">High</div>
      <div class="radio-btn active" data-val="balanced">Balanced</div>
      <div class="radio-btn" data-val="low-sens">Low</div>
    </div>
    <div class="profile-label">Novelty <span class="info-toggle" data-tip="novelty-tip">i</span></div>
    <div class="info-tip" id="novelty-tip">Depth: obsesses on one thing for months. Breadth: cycles through interests.</div>
    <div class="radio-group" data-dim="novelty">
      <div class="radio-btn" data-val="depth">Depth</div>
      <div class="radio-btn active" data-val="balanced">Balanced</div>
      <div class="radio-btn" data-val="breadth">Breadth</div>
    </div>
  </div>
  <div class="nav-links" id="nav-links"></div>
</div>
