<!-- SINGLE MOBILE FAB -->
<button class="profile-fab" id="fab-menu" title="Menu">&#9776;</button>

<!-- COMBINED FLOATING PANEL: sections + profile -->
<div class="profile-float" id="float-menu">
  <div id="float-menu-sections"></div>
  <div class="float-panel-divider">
    <div class="profile-float-title">Child Profile</div>
    <div class="profile-label">Energy</div>
    <div class="radio-group" data-dim="energy">
      <div class="radio-btn" data-val="introvert">Introvert</div>
      <div class="radio-btn active" data-val="balanced">Balanced</div>
      <div class="radio-btn" data-val="extrovert">Extrovert</div>
    </div>
    <div class="profile-label">Processing</div>
    <div class="radio-group" data-dim="processing">
      <div class="radio-btn" data-val="spatial">Spatial</div>
      <div class="radio-btn active" data-val="balanced">Balanced</div>
      <div class="radio-btn" data-val="verbal">Verbal</div>
    </div>
    <div class="profile-label">Sensitivity</div>
    <div class="radio-group" data-dim="sensitivity">
      <div class="radio-btn" data-val="high-sens">High</div>
      <div class="radio-btn active" data-val="balanced">Balanced</div>
      <div class="radio-btn" data-val="low-sens">Low</div>
    </div>
    <div class="profile-label">Novelty</div>
    <div class="radio-group" data-dim="novelty">
      <div class="radio-btn" data-val="depth">Depth</div>
      <div class="radio-btn active" data-val="balanced">Balanced</div>
      <div class="radio-btn" data-val="breadth">Breadth</div>
    </div>
  </div>
</div>

<!-- MOBILE SEARCH OVERLAY -->
<div id="mobile-search-overlay">
  <div id="mobile-search-bar">
    <input id="mobile-search-input" type="text" placeholder="Search…" autocomplete="off">
    <button id="mobile-search-close">✕</button>
  </div>
  <div id="mobile-search-results"></div>
</div>
