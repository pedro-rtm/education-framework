---
import { TAG_LABELS } from '../data/universes';

interface Props {
  phases: Array<{ data: { phaseId: string; label: string } }>;
}
const { phases } = Astro.props;

const tagEntries = Object.entries(TAG_LABELS).sort((a, b) => a[1].localeCompare(b[1]));
---

<div class="topbar">
  <div class="topbar-inner">
    <div class="logo">Education Framework</div>
    <div class="tabs" id="tabs">
      {phases.map((phase) => (
        <div
          class={`tab ${phase.data.phaseId === 'framework' ? 'active' : ''}`}
          data-tab={phase.data.phaseId}
        >
          {phase.data.label}
        </div>
      ))}
    </div>
    <div class="tabs hidden" id="domain-tabs"></div>
    <div class="tabs hidden" id="universe-tabs">
      <div class="tab" data-universe-tab="framework">Framework</div>
      <div class="tab active" data-universe-tab="all">All</div>
      {tagEntries.map(([key, label]) => (
        <div class="tab" data-universe-tab={key}>{label}</div>
      ))}
    </div>
    <div id="view-toggle">
      <span class="view-label">Journey:</span>
      <div class="view-btn active" data-view="age">Age</div>
      <div class="view-btn" data-view="domain">Domain</div>
      <div class="view-btn" data-view="universe">Universe</div>
      <select id="view-select" class="view-select">
        <option value="age" selected>Age</option>
        <option value="domain">Domain</option>
        <option value="universe">Universe</option>
      </select>
    </div>
    <div id="search-wrap">
      <svg id="search-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--text-muted)" stroke-width="2" stroke-linecap="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      <input id="search-input" type="text" placeholder="Search… (⌘K)" data-mobile-placeholder="Search…" autocomplete="off">
      <div id="search-results" class="hidden"></div>
    </div>
  </div>
</div>
