---
import { TAB_TAGS } from '../data/tags';

interface Props {
  phases: Array<{ data: { phaseId: string; label: string } }>;
}
const { phases } = Astro.props;

const tabEntries = Object.entries(TAB_TAGS);
---

<div class="topbar">
  <div class="topbar-inner">
    <button type="button" class="logo" id="nav-home" aria-label="Framework overview">Education Framework</button>

    <!-- Navigation dropdowns -->
    <div class="nav-dropdowns">
      <label class="nav-label" for="nav-view">View by</label>
      <select id="nav-view" class="nav-select">
        <option value="" disabled selected>Select view...</option>
        <option value="age">Age</option>
        <option value="domain">Domain</option>
        <option value="universe">Universe</option>
      </select>
      <select id="nav-item" class="nav-select nav-item-select" disabled>
        <option value="" disabled selected>Select...</option>
      </select>
    </div>

    <!-- Phase data for JS (no visible tabs) -->
    <script is:inline define:vars={{ phaseData: phases.filter(p => p.data.phaseId !== 'framework').map(p => ({ id: p.data.phaseId, label: p.data.label })), universeTabData: tabEntries.map(([key, label]) => ({ key, label })) }}>
      window.__phaseData = phaseData;
      window.__universeTabData = universeTabData;
    </script>

    <div id="search-wrap">
      <button id="search-icon" type="button" aria-label="Search">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--text-muted)" stroke-width="2" stroke-linecap="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      </button>
      <input id="search-input" type="text" placeholder="Search… (⌘K)" data-mobile-placeholder="Search…" autocomplete="off">
      <div id="search-results" class="hidden"></div>
    </div>
  </div>
</div>
