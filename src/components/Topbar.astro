---
import { TAB_TAGS } from '../data/tags';

interface Props {
  phases: Array<{ data: { phaseId: string; label: string } }>;
  domainCount?: number;
  universeCount?: number;
  lang?: string;
}
const { phases, domainCount = 0, universeCount = 0, lang = 'en' } = Astro.props;

const agePhases = phases.filter(p => p.data.phaseId !== 'framework');
const tabEntries = Object.entries(TAB_TAGS);

const nav = lang === 'es' ? {
  home: 'Inicio', framework: 'Marco', byAge: 'Por Edad', acrossAges: 'A Través de las Edades',
  targets: 'Mapa de Actividades', models: 'Modelos Mentales', domains: 'Dominios',
  resources: 'Recursos', library: 'Biblioteca', search: 'Buscar...'
} : {
  home: 'Home', framework: 'Framework', byAge: 'By Age', acrossAges: 'Across Ages',
  targets: 'Activity Map', models: 'Mental Models', domains: 'Domains',
  resources: 'Resources', library: 'Library', search: 'Search... (⌘K)'
};
---

<nav class="topbar" role="navigation" aria-label="Main navigation">
  <div class="topbar-inner">
    <!-- Logo / Home -->
    <button type="button" class="nav-logo" id="nav-home" aria-label="Home">
      <span class="nav-logo-mark">EF</span>
      <span class="nav-logo-text">Education Framework</span>
    </button>

    <!-- Main navigation -->
    <div class="nav-items" id="nav-items">
      <button type="button" class="nav-item active" data-view="home">{nav.home}</button>
      <button type="button" class="nav-item" data-view="framework">{nav.framework}</button>

      <!-- By Age — dropdown trigger -->
      <div class="nav-dropdown-wrap">
        <button type="button" class="nav-item" data-view="age" aria-expanded="false" aria-haspopup="true">
          {nav.byAge}
          <svg class="nav-chevron" width="10" height="6" viewBox="0 0 10 6" fill="none"><path d="M1 1L5 5L9 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
        </button>
        <div class="nav-dropdown" role="menu">
          {agePhases.map((phase) => (
            <button type="button" class="nav-dropdown-item" role="menuitem" data-phase={phase.data.phaseId}>
              <span class="nav-dropdown-label">{phase.data.label}</span>
            </button>
          ))}
        </div>
      </div>

      <!-- Across Ages — dropdown trigger -->
      <div class="nav-dropdown-wrap">
        <button type="button" class="nav-item" data-view="across-ages" aria-expanded="false" aria-haspopup="true">
          {nav.acrossAges}
          <svg class="nav-chevron" width="10" height="6" viewBox="0 0 10 6" fill="none"><path d="M1 1L5 5L9 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
        </button>
        <div class="nav-dropdown" role="menu" id="nav-across-dropdown">
          <button type="button" class="nav-dropdown-item" role="menuitem" data-across-view="targets">{nav.targets}</button>
          <button type="button" class="nav-dropdown-item" role="menuitem" data-across-view="models">{nav.models}</button>
          <button type="button" class="nav-dropdown-item" role="menuitem" data-across-view="domain">{nav.domains}</button>
          <button type="button" class="nav-dropdown-item" role="menuitem" data-across-view="resources">{nav.resources}</button>
          <button type="button" class="nav-dropdown-item" role="menuitem" data-across-view="universe">{nav.library}</button>
        </div>
      </div>
    </div>

    <!-- Language switcher -->
    <a class="lang-switch" id="lang-switch" href="" aria-label="Switch language">
      <span class="lang-switch-label"></span>
    </a>

    <!-- Search -->
    <div id="search-wrap">
      <button id="search-icon" type="button" aria-label="Search">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      </button>
      <input id="search-input" type="text" placeholder={nav.search} autocomplete="off">
      <div id="search-results" class="hidden"></div>
    </div>

    <!-- Mobile hamburger -->
    <button type="button" class="nav-hamburger" id="nav-hamburger" aria-label="Menu" aria-expanded="false">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>
</nav>

<!-- Mobile slide-down menu -->
<div class="mobile-menu hidden" id="mobile-menu">
  <button type="button" class="mobile-menu-item" data-view="home">{nav.home}</button>
  <button type="button" class="mobile-menu-item" data-view="framework">{nav.framework}</button>
  <div class="mobile-menu-group">
    <div class="mobile-menu-label">{nav.byAge}</div>
    {agePhases.map((phase) => (
      <button type="button" class="mobile-menu-item mobile-menu-sub" data-view="age" data-phase={phase.data.phaseId}>
        {phase.data.label}
      </button>
    ))}
  </div>
  <div class="mobile-menu-group">
    <div class="mobile-menu-label">{nav.acrossAges}</div>
    <button type="button" class="mobile-menu-item mobile-menu-sub" data-across-view="targets">{nav.targets}</button>
    <button type="button" class="mobile-menu-item mobile-menu-sub" data-across-view="models">{nav.models}</button>
    <button type="button" class="mobile-menu-item mobile-menu-sub" data-across-view="domain">{nav.domains}</button>
    <button type="button" class="mobile-menu-item mobile-menu-sub" data-across-view="resources">{nav.resources}</button>
    <button type="button" class="mobile-menu-item mobile-menu-sub" data-across-view="universe">{nav.library}</button>
  </div>
  <div class="mobile-menu-group" style="border-top: 1px solid var(--border); margin-top: var(--sp-3); padding-top: var(--sp-3);">
    <a class="mobile-menu-item" id="lang-switch-mobile" href=""></a>
  </div>
</div>

<!-- Pass data to JS -->
<script is:inline define:vars={{ phaseData: agePhases.map(p => ({ id: p.data.phaseId, label: p.data.label })), universeTabData: tabEntries.map(([key, label]) => ({ key, label })) }}>
  window.__phaseData = phaseData;
  window.__universeTabData = universeTabData;
</script>
