---
import { getCollection } from 'astro:content';
import '../../styles/global.css';
import Topbar from '../../components/Topbar.astro';
import Home from '../../components/Home.astro';
import Sidebar from '../../components/Sidebar.astro';
import FloatingPanel from '../../components/FloatingPanel.astro';
import UniverseView from '../../components/UniverseView.astro';
import ModelsView from '../../components/ModelsView.astro';
import TargetsView from '../../components/TargetsView.astro';
import ResourcesView from '../../components/ResourcesView.astro';
import PhaseUniverses from '../../components/PhaseUniverses.astro';

const phases = (await getCollection('phases-es')).sort((a, b) => a.data.order - b.data.order);
const universes = await getCollection('universes-es');

const renderedPhases = await Promise.all(
  phases.map(async (phase) => {
    const { Content } = await phase.render();
    return { ...phase, Content };
  })
);

const agePhaseCount = phases.filter(p => p.data.phaseId !== 'framework').length;
---

<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Marco Educativo</title>
  <meta name="description" content="Un marco educativo estructurado por fases para el desarrollo infantil desde el nacimiento hasta los 18 años.">

  <link rel="icon" type="image/svg+xml" href="/education-framework/favicon.svg">
  <link rel="icon" type="image/png" sizes="32x32" href="/education-framework/favicon-32.png">
  <link rel="apple-touch-icon" href="/education-framework/apple-touch-icon.png">

  <meta property="og:type" content="website">
  <meta property="og:url" content="https://pedro-rtm.github.io/education-framework/es/">
  <meta property="og:title" content="Marco Educativo">
  <meta property="og:description" content="Un marco educativo estructurado por fases para el desarrollo infantil desde el nacimiento hasta los 18 años.">
  <meta property="og:image" content="https://pedro-rtm.github.io/education-framework/og-image.png">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:ital,opsz,wght@0,9..40,300..700;1,9..40,300..700&family=Material+Symbols+Rounded:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&display=swap" rel="stylesheet">
  <style is:inline>
  .material-symbols-rounded {
    font-family: 'Material Symbols Rounded';
    font-variation-settings: 'FILL' 0, 'wght' 300, 'GRAD' 0, 'opsz' 20;
    font-size: 20px;
    vertical-align: -4px;
    margin-right: 6px;
    color: var(--accent);
    user-select: none;
    font-style: normal;
    font-weight: normal;
    line-height: 1;
    letter-spacing: normal;
    white-space: nowrap;
    direction: ltr;
  }
  h2 .material-symbols-rounded { font-size: 22px; vertical-align: -5px; }
  </style>
</head>
<body>
<div class="app">
  <Topbar phases={phases} universeCount={universes.length} lang="es" />

  <div class="main-layout">
    <div class="content" id="content">
      <Home phaseCount={agePhaseCount} universeCount={universes.length} lang="es" />

      {renderedPhases.map((phase) => (
        <div
          class="phase-content"
          data-phase={phase.data.phaseId}
          data-label={phase.data.label}
        >
          <phase.Content />
          <PhaseUniverses phaseId={phase.data.phaseId} collection="universes-es" />
        </div>
      ))}

      <div id="domain-view" class="hidden">
        <div id="domain-header"></div>
        <div id="domain-timeline"></div>
      </div>

      <UniverseView collection="universes-es" />

      <!-- Across Ages views -->
      <TargetsView lang="es" />
      <ModelsView lang="es" />
      <ResourcesView lang="es" />
    </div>

    <Sidebar lang="es" />
  </div>
</div>

<FloatingPanel />

<div id="mobile-search-overlay">
  <div id="mobile-search-bar">
    <input id="mobile-search-input" type="text" placeholder="Buscar..." autocomplete="off">
    <button id="mobile-search-close" type="button" aria-label="Cerrar búsqueda">&times;</button>
  </div>
  <div id="mobile-search-results"></div>
</div>

<script src="../../scripts/app.js"></script>
</body>
</html>
